# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# Android build outputs
android/app/build/
android/.gradle/
android/build/
_app-store-assets/keystore.txt
*.apk

debug/

# Tool-generated
.claude/settings.json
src/**/.ai/

# Design system architect — contains secrets / ephemeral output
.mcp.json
src/ui/drift-report.md
figma-export.json

# Design system — auto-generated metadata files (regenerated by /design-system-architect metadata)
# These are regenerated from source — safe to gitignore
src/ui/*.metadata.ts
src/ui/design-system.metadata.ts
src/ui/audit-report.json

# Design system — COMMITTED to git (contain Figma IDs + token definitions that must persist)
# Do NOT add these back to .gitignore
# src/ui/design-system-manifest.json  ← Figma file key + variable IDs + component node IDs
# src/ui/design-tokens.json           ← W3C token definitions with $extensions governance metadata
.claude/scheduled_tasks.lock
release.keystore
release.keystore.properties
gradle.properties.release
