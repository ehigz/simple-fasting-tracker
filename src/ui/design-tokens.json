{
  "InterFast": {
    "Primitives": {
      "purple": {
        "950": { "$type": "color", "$value": "#340247", "$description": "Deepest purple — primary text, icons, borders", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "900": { "$type": "color", "$value": "#4a0360", "$description": "Deep purple — pressed/hover state",              "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "600": { "$type": "color", "$value": "#6e5fa7", "$description": "Mid purple — secondary button text, icon tint",  "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "500": { "$type": "color", "$value": "#8b7db8", "$description": "Medium purple — hover state for accent elements","$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "400": { "$type": "color", "$value": "#a89fc9", "$description": "Light-mid purple — inactive tab icons",           "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "200": { "$type": "color", "$value": "#d4cfe6", "$description": "Light purple tint — subtle accent surfaces",      "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "100": { "$type": "color", "$value": "#e6e3ed", "$description": "Very light purple — disabled button background",  "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "75":  { "$type": "color", "$value": "#eeebf4", "$description": "Near-white purple — subtle surface background",   "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "50":  { "$type": "color", "$value": "#f4ecff", "$description": "Palest purple — card fills, icon container bg",   "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      },
      "neutral": {
        "500": { "$type": "color", "$value": "#6b6b7e", "$description": "Mid grey-purple — muted text, labels, body copy", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      },
      "white": { "$type": "color", "$value": "#ffffff", "$description": "Pure white — card backgrounds, primary button text", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
      "amber": {
        "50":  { "$type": "color", "$value": "#fff9f0", "$description": "Warm off-white — warning card background", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "600": { "$type": "color", "$value": "#d97706", "$description": "Amber — warning icon / anabolic zone",      "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } },
        "700": { "$type": "color", "$value": "#b45309", "$description": "Dark amber — immune reset zone",            "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      },
      "lime": {
        "600": { "$type": "color", "$value": "#65a30d", "$description": "Lime — catabolic zone",  "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      },
      "emerald": {
        "600": { "$type": "color", "$value": "#059669", "$description": "Emerald — fat burning zone", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      },
      "teal": {
        "700": { "$type": "color", "$value": "#0f766e", "$description": "Teal — autophagy zone", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      },
      "stone": {
        "600": { "$type": "color", "$value": "#57534e", "$description": "Stone — deep autophagy zone", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      },
      "green": {
        "800": { "$type": "color", "$value": "#166534", "$description": "Green — stem cell zone", "$extensions": { "interfast": { "status": "stable", "tier": "primitive" } } }
      }
    },
    "colors": {
      "primary":      { "$type": "color", "$value": "{InterFast.Primitives.purple.950}", "$description": "Main text, icons, borders",                      "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["text", "icons", "borders", "outlines"], "doNotUseFor": ["backgrounds", "fills"], "adrRef": "docs/decisions/0005-three-tier-token-model.md" } } },
      "primaryHover": { "$type": "color", "$value": "{InterFast.Primitives.purple.900}", "$description": "Pressed state of primary",                       "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["pressed-state"], "doNotUseFor": ["default-state"] } } },
      "secondary":    { "$type": "color", "$value": "{InterFast.Primitives.purple.50}",  "$description": "Light purple bg — icon containers, secondary btn","$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["backgrounds", "fills", "icon-containers"] } } },
      "muted":        { "$type": "color", "$value": "{InterFast.Primitives.purple.100}", "$description": "Disabled button background",                     "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["disabled-backgrounds"] } } },
      "mutedFg":      { "$type": "color", "$value": "{InterFast.Primitives.neutral.500}","$description": "Muted text, field labels, body copy",             "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["text", "labels", "body-copy", "disabled-text"] } } },
      "accent":       { "$type": "color", "$value": "{InterFast.Primitives.purple.200}", "$description": "Subtle accent surfaces",                         "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["accent-surfaces"] } } },
      "accentPurple": { "$type": "color", "$value": "{InterFast.Primitives.purple.600}", "$description": "Secondary button text and icon tint",             "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["secondary-button-text", "icon-tint"] } } },
      "accentLight":  { "$type": "color", "$value": "{InterFast.Primitives.purple.400}", "$description": "Inactive tab icons",                             "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["inactive-tab-icons"] } } },
      "accentHover":  { "$type": "color", "$value": "{InterFast.Primitives.purple.500}", "$description": "Hover/pressed state for accent elements",         "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["accent-hover"] } } },
      "surface":      { "$type": "color", "$value": "{InterFast.Primitives.purple.75}",  "$description": "Subtle surface background",                      "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["surface-backgrounds"] } } },
      "warn":         { "$type": "color", "$value": "{InterFast.Primitives.amber.50}",   "$description": "Warning card background",                        "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["warning-backgrounds"] } } },
      "warnIcon":     { "$type": "color", "$value": "{InterFast.Primitives.amber.600}",  "$description": "Warning icon color",                             "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["warning-icons"] } } },
      "white":        { "$type": "color", "$value": "{InterFast.Primitives.white}",      "$description": "Pure white — card backgrounds, primary button text","$extensions": { "interfast": { "status": "stable", "tier": "semantic", "usageScope": ["card-backgrounds", "primary-button-text"] } } },
      "tabBarBg":          { "$type": "color", "$value": "rgba(255, 255, 255, 0.92)", "$description": "Tab bar frosted glass background",                "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:8", "usageScope": ["tab-bar-only"] } } },
      "tabBarBorder":      { "$type": "color", "$value": "rgba(52, 2, 71, 0.12)",   "$description": "Tab bar top border",                             "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:9", "usageScope": ["tab-bar-only"] } } },
      "zoneAnabolic":      { "$type": "color", "$value": "{InterFast.Primitives.amber.600}",   "$description": "Anabolic zone (4h) progress bar color",      "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:10" } } },
      "zoneCatabolic":     { "$type": "color", "$value": "{InterFast.Primitives.lime.600}",    "$description": "Catabolic zone (12h) progress bar color",    "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:11" } } },
      "zoneFatBurning":    { "$type": "color", "$value": "{InterFast.Primitives.emerald.600}", "$description": "Fat Burning zone (16h) progress bar color",  "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:12" } } },
      "zoneAutophagy":     { "$type": "color", "$value": "{InterFast.Primitives.teal.700}",    "$description": "Autophagy zone (18h) progress bar color",    "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:13" } } },
      "zoneDeepAutophagy": { "$type": "color", "$value": "{InterFast.Primitives.stone.600}",   "$description": "Deep Autophagy zone (24h) progress bar color","$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:14" } } },
      "zoneImmuneReset":   { "$type": "color", "$value": "{InterFast.Primitives.amber.700}",   "$description": "Immune Reset zone (48h) progress bar color", "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:15" } } },
      "zoneStemCell":      { "$type": "color", "$value": "{InterFast.Primitives.green.800}",   "$description": "Stem Cell zone (72h) progress bar color",    "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:16" } } }
    },
    "radius": {
      "sm":   { "$type": "number", "$value": 12,   "$description": "rounded-xl (12px) — small controls, stop button",  "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "tailwindClass": "rounded-xl",   "usageScope": ["small-controls"] } } },
      "md":   { "$type": "number", "$value": 16,   "$description": "rounded-2xl (16px) — buttons, inputs, list cards", "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "tailwindClass": "rounded-2xl",  "usageScope": ["buttons", "inputs", "list-cards"] } } },
      "lg":   { "$type": "number", "$value": 24,   "$description": "rounded-3xl (24px) — main content cards",          "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "tailwindClass": "rounded-3xl",  "usageScope": ["main-cards"] } } },
      "full": { "$type": "number", "$value": 9999, "$description": "Fully rounded pill — progress bars, badges",       "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "tailwindClass": "rounded-full", "figmaVariableId": "VariableID:8:17" } } }
    },
    "motion": {
      "duration": {
        "fast":     { "$type": "number", "$value": 200,   "$description": "Micro interactions — badge appear, FadeOut",           "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:19", "usageScope": ["micro-interactions"] } } },
        "base":     { "$type": "number", "$value": 300,   "$description": "Standard transitions — FadeIn, SlideIn, Layout",      "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:20", "usageScope": ["standard-transitions"] } } },
        "slow":     { "$type": "number", "$value": 500,   "$description": "Emphasis animations — hero enters, staggered reveals", "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:21", "usageScope": ["emphasis"] } } },
        "progress": { "$type": "number", "$value": 1000,  "$description": "Progress bar fill animation",                         "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:22", "usageScope": ["progress-bars"] } } },
        "ambient":  { "$type": "number", "$value": 15000, "$description": "Breathing / looping background animations",           "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:23", "usageScope": ["ambient-loops"] } } }
      }
    },
    "layout": {
      "screen":  { "paddingH": { "$type": "number", "$value": 16, "$description": "Horizontal screen edge padding (NativeWind: px-4)", "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:25" } } } },
      "header":  { "offset":   { "$type": "number", "$value": 96, "$description": "paddingTop to clear status bar + header",           "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:26" } } } },
      "tabBar":  { "offset":   { "$type": "number", "$value": 32, "$description": "paddingBottom to clear tab bar",                   "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "figmaVariableId": "VariableID:8:27" } } } }
    },
    "components": {
      "button": {
        "primary": {
          "fill":        { "$type": "color", "$value": "{InterFast.colors.primary}",      "$description": "Primary button background",      "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:29" } } },
          "fillPressed": { "$type": "color", "$value": "{InterFast.colors.primaryHover}", "$description": "Primary button pressed state",    "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:30" } } },
          "label":       { "$type": "color", "$value": "{InterFast.colors.white}",        "$description": "Primary button label text",       "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:31" } } }
        },
        "secondary": {
          "fill":   { "$type": "color", "$value": "{InterFast.colors.secondary}",    "$description": "Secondary button background",              "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:32" } } },
          "label":  { "$type": "color", "$value": "{InterFast.colors.accentPurple}", "$description": "Secondary button label text",              "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:33" } } },
          "border": { "$type": "color", "$value": "rgba(52, 2, 71, 0.10)",           "$description": "Secondary button border (primary/10)",     "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:34" } } }
        },
        "ghost": {
          "label":  { "$type": "color", "$value": "{InterFast.colors.primary}",  "$description": "Ghost button label text",          "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:35" } } },
          "border": { "$type": "color", "$value": "rgba(52, 2, 71, 0.12)",       "$description": "Ghost button border (primary/12)", "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:36" } } }
        },
        "disabled": {
          "fill":  { "$type": "color", "$value": "{InterFast.colors.muted}",   "$description": "Disabled button background", "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:37" } } },
          "label": { "$type": "color", "$value": "{InterFast.colors.mutedFg}", "$description": "Disabled button label text", "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:38" } } }
        }
      },
      "card": {
        "fill":   { "$type": "color",  "$value": "rgba(255, 255, 255, 0.95)", "$description": "Card background (white/95)",      "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:39" } } },
        "border": { "$type": "color",  "$value": "rgba(52, 2, 71, 0.08)",     "$description": "Card border (primary/8)",          "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:40" } } },
        "radius": {
          "default": { "$type": "number", "$value": "{InterFast.radius.lg}", "$description": "Card radius — default (24px)", "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:41" } } },
          "sm":      { "$type": "number", "$value": "{InterFast.radius.md}", "$description": "Card radius — sm variant (16px)", "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:42" } } }
        }
      },
      "tabBar": {
        "fill":         { "$type": "color", "$value": "{InterFast.colors.tabBarBg}",     "$description": "Tab bar frosted background", "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:43" } } },
        "border":       { "$type": "color", "$value": "{InterFast.colors.tabBarBorder}", "$description": "Tab bar top border",          "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:44" } } },
        "iconActive":   { "$type": "color", "$value": "{InterFast.colors.primary}",      "$description": "Active tab icon",             "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:45" } } },
        "iconInactive": { "$type": "color", "$value": "{InterFast.colors.accentLight}",  "$description": "Inactive tab icon",           "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:46" } } }
      },
      "zone": {
        "fill": {
          "active":   { "$type": "color", "$value": "{InterFast.colors.secondary}", "$description": "Completed zone card background",      "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:47" } } },
          "inactive": { "$type": "color", "$value": "rgba(255, 255, 255, 0.50)",    "$description": "Active zone card background (white/50)","$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:48" } } }
        },
        "border": {
          "active":   { "$type": "color", "$value": "{InterFast.colors.accentLight}", "$description": "Completed zone card border",   "$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:49" } } },
          "inactive": { "$type": "color", "$value": "rgba(52, 2, 71, 0.08)",          "$description": "Active zone card border (primary/8)","$extensions": { "interfast": { "status": "stable", "tier": "component", "figmaVariableId": "VariableID:8:50" } } }
        }
      }
    },
    "typography": {
      "overline":   { "$type": "number", "$value": 12, "$description": "All-caps overline with ✦ star decorators. Section headers only.", "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "weight": "400", "transform": "uppercase", "letterSpacing": "widest", "opacity": 0.6 } } },
      "fieldLabel": { "$type": "number", "$value": 12, "$description": "All-caps label above inputs or stat pairs.",                      "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "weight": "400", "transform": "uppercase", "letterSpacing": "widest" } } },
      "cardTitle":  { "$type": "number", "$value": 24, "$description": "Primary card heading. One per card.",                             "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "weight": "600", "tracking": "tight" } } },
      "bodyText":   { "$type": "number", "$value": 16, "$description": "Body/description copy. Muted color.",                            "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "weight": "400", "lineHeight": "relaxed" } } },
      "mutedText":  { "$type": "number", "$value": 14, "$description": "Timestamps, subtitles, helper text.",                            "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "weight": "400" } } },
      "statValue":  { "$type": "number", "$value": 18, "$description": "Numeric data values. Use className='text-xl' for hero metrics.", "$extensions": { "interfast": { "status": "stable", "tier": "semantic", "weight": "600" } } }
    }
  }
}
